    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>প্রমোশন বোনাস ধাপ</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            padding: 0;
            text-align: center;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: #fff;
            padding: 80px 20px 20px 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }
        h2 {
            color: #333;
        }
        .step {
            background: #e3f2fd;
            padding: 20px;
            margin: 15px 0;
            border-left: 5px solid #2196F3;
            border-radius: 8px;
            text-align: left;
        }
        .step h3 {
            margin: 0;
            color: #0D47A1;
        }
        .step p {
            margin-top: 10px;
            color: #333;
        }
    </style>
