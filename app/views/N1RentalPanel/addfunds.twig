{% include 'header.twig' %}
<style>
  .addfunds-shell {
    padding: 24px 0 40px;
    background:
      radial-gradient(circle at top left, rgba(255, 164, 0, 0.18), transparent 28%),
      radial-gradient(circle at top right, rgba(42, 42, 114, 0.14), transparent 26%),
      linear-gradient(180deg, #f6f8fc 0%, #eef2f7 100%);
  }

  .card_v2 {
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }

  .tutorial-card .card-body,
  .gateway-card .card-body,
  .policy-card .card-body,
  .main-card .card-body {
    padding: 24px;
  }

  .section-title {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 18px;
  }

  .section-title .eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6b7280;
    font-weight: 700;
  }

  .section-title h2,
  .section-title h3 {
    margin: 0;
    font-weight: 800;
    color: #0f172a;
  }

  .title-line {
    width: 88px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, #ff9f1c, #2a2a72);
  }

  .lead-copy {
    color: #475569;
    line-height: 1.8;
    margin-bottom: 18px;
  }

  .support-alert {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(42, 42, 114, 0.08), rgba(255, 164, 0, 0.08));
    border: 1px solid rgba(42, 42, 114, 0.12);
    color: #1e293b;
    margin-bottom: 18px;
  }

  .support-alert i {
    color: #2a2a72;
    margin-top: 2px;
    font-size: 18px;
  }

  .premium-balance-card {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    padding: 18px 20px;
    background: linear-gradient(135deg, #0f172a 0%, #2a2a72 55%, #ff9f1c 130%);
    color: #fff;
    margin-bottom: 18px;
    min-height: 126px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .premium-balance-card::after {
    content: "";
    position: absolute;
    inset: auto -30px -30px auto;
    width: 180px;
    height: 180px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
  }

  .balance-copy .label {
    display: inline-block;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.82;
    margin-bottom: 8px;
  }

  .balance-copy .amount {
    margin: 0;
    font-size: 34px;
    font-weight: 800;
    line-height: 1;
  }

  .balance-copy .subline {
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.82);
    font-size: 14px;
  }

  .balance-icon {
    width: 74px;
    height: 74px;
    display: grid;
    place-items: center;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
    font-size: 30px;
    z-index: 1;
    position: relative;
    flex: 0 0 auto;
  }

  .video-frame {
    border-radius: 20px;
    overflow: hidden;
    min-height: 260px;
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.92), rgba(42, 42, 114, 0.9)),
      radial-gradient(circle at top right, rgba(255, 164, 0, 0.55), transparent 34%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .video-frame::before {
    content: "";
    position: absolute;
    inset: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
  }

  .video-copy {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    max-width: 320px;
    padding: 24px;
  }

  .video-play {
    width: 82px;
    height: 82px;
    margin: 0 auto 18px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #ff9f1c, #f97316);
    box-shadow: 0 18px 35px rgba(249, 115, 22, 0.35);
    font-size: 30px;
  }

  .video-copy h4 {
    margin: 0 0 8px;
    font-weight: 800;
  }

  .video-copy p {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
  }

  .tab_btn_wrap {
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .tab_btn_wrap .nav-link {
    border: 0;
    border-radius: 999px;
    padding: 12px 18px;
    background: #eef2f7;
    color: #0f172a;
    font-weight: 700;
    box-shadow: none;
  }

  .tab_btn_wrap .nav-link.active {
    background: linear-gradient(135deg, #2a2a72, #ff9f1c);
    color: #fff;
    box-shadow: 0 12px 24px rgba(42, 42, 114, 0.22);
  }

  .tab_wrap {
    padding-top: 18px;
  }

  .gateway-shell {
    display: grid;
    gap: 14px;
    margin-bottom: 18px;
  }

  .gateway-quick-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .gateway-quick-item {
    width: 100%;
    min-height: 86px;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 20px;
    background:
      linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    text-align: left;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
  }

  .gateway-quick-item:hover,
  .gateway-quick-item.is-active {
    border-color: rgba(96, 47, 255, 0.28);
    box-shadow: 0 16px 30px rgba(96, 47, 255, 0.12);
    transform: translateY(-2px);
    background:
      linear-gradient(180deg, #f5efff 0%, #ffffff 100%);
  }

  .gateway-quick-item .logo {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    object-fit: contain;
    background: #f8fafc;
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.06);
    font-size: 14px;
    font-weight: 800;
  }

  .gateway-quick-item .meta {
    min-width: 0;
  }

  .gateway-quick-item .meta strong {
    display: block;
    color: #0f172a;
    font-size: 15px;
    line-height: 1.2;
    font-weight: 800;
  }

  .gateway-quick-item .meta span {
    display: none;
  }

  .converter-panel {
    margin-bottom: 18px;
    padding: 18px;
    border-radius: 22px;
    background:
      linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    border: 1px solid rgba(148, 163, 184, 0.2);
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.05);
  }

  .converter-panel .converter-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .converter-panel .converter-head h4 {
    margin: 0;
    font-size: 17px;
    font-weight: 800;
    color: #0f172a;
  }

  .converter-panel .rate-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 999px;
    background: #fff;
    color: #2a2a72;
    font-weight: 700;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
    white-space: nowrap;
  }

  .quick-amounts {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 16px;
  }

  .quick-amounts button {
    border: 1px solid rgba(148, 163, 184, 0.28);
    background: #fff;
    color: #1e293b;
    border-radius: 14px;
    min-width: 58px;
    height: 46px;
    padding: 0 14px;
    font-weight: 700;
    box-shadow: 0 6px 14px rgba(15, 23, 42, 0.04);
    transition: all 0.18s ease;
  }

  .quick-amounts button:hover,
  .quick-amounts button.is-active {
    background: linear-gradient(135deg, #6734f6, #8d55ff);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 14px 24px rgba(103, 52, 246, 0.22);
  }

  .converter-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 14px;
    align-items: end;
  }

  .converter-grid .swap-icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 14px;
    background: #fff;
    color: #2a2a72;
    font-size: 18px;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
    margin-bottom: 2px;
  }

  .converter-grid .form-control[readonly] {
    background: #edf5ff;
    cursor: not-allowed;
  }

  .rate-summary {
    margin-top: 16px;
    border-radius: 18px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    padding: 16px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
  }

  .rate-summary .copy {
    display: grid;
    gap: 4px;
  }

  .rate-summary .copy .eyebrow {
    color: #64748b;
    font-size: 12px;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .rate-summary .copy .value {
    color: #0f172a;
    font-size: 32px;
    font-weight: 900;
    line-height: 1;
  }

  .rate-summary .badge-note {
    flex: 0 0 auto;
    border-radius: 14px;
    padding: 12px 16px;
    background: linear-gradient(135deg, rgba(103, 52, 246, 0.1), rgba(103, 52, 246, 0.16));
    color: #4c1d95;
    font-weight: 800;
    font-size: 14px;
    text-align: center;
  }

  .rate-summary .breakdown-note {
    flex: 0 0 100%;
    margin-top: 2px;
    color: #64748b;
    font-size: 14px;
    font-weight: 700;
    text-align: left;
  }

  .pay-action {
    margin-top: 18px;
    border: 0;
    min-height: 56px;
    border-radius: 14px;
    background: linear-gradient(90deg, #5b25ef 0%, #19b5d8 100%);
    font-size: 17px;
    font-weight: 800;
    box-shadow: 0 18px 34px rgba(25, 181, 216, 0.2);
  }

  .pay-action:hover,
  .pay-action:focus,
  .pay-action:active {
    background: linear-gradient(90deg, #5b25ef 0%, #19b5d8 100%) !important;
    border: 0 !important;
    box-shadow: 0 18px 34px rgba(25, 181, 216, 0.2) !important;
  }

  .form-control,
  .form-select {
    min-height: 48px;
    border-radius: 14px;
    border-color: rgba(15, 23, 42, 0.12);
    box-shadow: none !important;
  }

  #addfunds_fields .form-group + .form-group {
    margin-top: 14px;
  }

  .method-box {
    margin-top: 14px;
    border-radius: 16px;
    background: #f8fafc;
    border: 1px solid rgba(15, 23, 42, 0.08);
    padding: 16px;
  }

  .method-box .panel-body {
    color: #334155;
    line-height: 1.75;
    word-break: break-word;
  }

  .fee-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .history-table {
    overflow-x: auto;
  }

  .history-table table {
    margin-bottom: 0;
  }

  .history-table thead th {
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    color: #dc2626;
    font-weight: 800;
    white-space: nowrap;
  }

  .history-table tbody td {
    vertical-align: middle;
    white-space: nowrap;
    color: #334155;
  }

  .info-card .card-header,
  .policy-card .card-header {
    background: linear-gradient(135deg, #0f172a, #2a2a72);
    color: #fff;
    border-bottom: 0;
    padding: 18px 24px;
  }

  .header-title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 800;
  }

  .header-title .icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.12);
    display: grid;
    place-items: center;
    flex: 0 0 auto;
  }

  .gateway-copy {
    color: #475569;
    line-height: 1.85;
  }

  .policy-card ul {
    padding-left: 20px;
    margin: 0;
    color: #334155;
    line-height: 1.8;
  }

  .policy-card li + li {
    margin-top: 8px;
  }

  .content-stack {
    display: grid;
    gap: 22px;
  }

  .floating-support {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 9999;
  }

  .floating-support a {
    width: 58px;
    height: 58px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    box-shadow: 0 16px 30px rgba(18, 140, 126, 0.35);
    text-decoration: none;
    font-size: 28px;
  }

  @media (max-width: 991px) {
    .gateway-quick-grid,
    .converter-grid {
      grid-template-columns: 1fr;
    }

    .converter-panel .converter-head,
    .rate-summary {
      flex-direction: column;
      align-items: flex-start;
    }

    .premium-balance-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .balance-icon {
      width: 62px;
      height: 62px;
      font-size: 26px;
    }

    .fee-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .addfunds-shell {
      padding: 14px 0 28px;
    }

    .main-card .card-body,
    .policy-card .card-body,
    .tutorial-card .card-body,
    .gateway-card .card-body {
      padding: 14px;
    }

    .tab_btn_wrap {
      gap: 8px;
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 4px;
      -webkit-overflow-scrolling: touch;
    }

    .tab_btn_wrap .nav-link {
      padding: 9px 14px;
      font-size: 14px;
      white-space: nowrap;
      flex: 0 0 auto;
    }

    .gateway-shell {
      gap: 10px;
      margin-bottom: 14px;
    }

    .gateway-quick-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }

    .gateway-quick-item {
      min-height: 46px;
      padding: 8px 0;
      justify-content: center;
      border-radius: 14px;
    }

    .gateway-quick-item .logo {
      width: 30px;
      height: 30px;
      border-radius: 10px;
      font-size: 12px;
    }

    .gateway-quick-item .meta {
      display: none;
    }

    .form-group > label,
    .control-label {
      font-size: 14px;
      margin-bottom: 6px;
    }

    .form-control,
    .form-select {
      min-height: 44px;
      border-radius: 12px;
    }

    .converter-panel {
      padding: 14px;
      border-radius: 18px;
      margin-bottom: 14px;
    }

    .converter-panel .converter-head h4 {
      font-size: 15px;
    }

    .converter-panel .rate-badge {
      padding: 7px 10px;
      font-size: 12px;
    }

    .quick-amounts {
      gap: 8px;
      margin-bottom: 14px;
    }

    .quick-amounts button {
      min-width: 48px;
      height: 40px;
      padding: 0 10px;
      border-radius: 12px;
      font-size: 13px;
    }

    .converter-grid {
      gap: 10px;
    }

    .converter-grid .swap-icon {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      font-size: 16px;
      align-self: center;
      margin-bottom: 0;
    }

    .rate-summary {
      padding: 14px;
      gap: 10px;
    }

    .rate-summary .copy .value {
      font-size: 26px;
    }

    .rate-summary .badge-note {
      width: 100%;
      font-size: 13px;
      padding: 10px 12px;
    }

    .rate-summary .breakdown-note {
      font-size: 13px;
      line-height: 1.45;
    }

    .pay-action {
      min-height: 50px;
      font-size: 16px;
      margin-top: 14px;
      border-radius: 12px;
    }

    .method-box {
      padding: 14px;
      border-radius: 14px;
    }

    .policy-card {
      display: none;
    }

    .content-stack {
      gap: 16px;
    }
  }
</style>

  <div class="addfunds-shell">
  <div class="container-fluid">
    <div class="content-stack">
      <div class="row g-4">
        <div class="col-lg-7">
          <div class="card_v2 main-card h-100">
            <div class="card-body">
              <div id="newOrderTabsWrap">
                <ul class="nav nav-pills tab_btn_wrap mb-0" id="pills-tab" role="tablist">
                  <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="pills-order-tab" data-bs-toggle="pill" data-bs-target="#pills-order" type="button" role="tab" aria-controls="pills-order" aria-selected="true">
                      <i class="far fa-credit-card"></i> Add Fund
                    </button>
                  </li>
                  <li class="nav-item" role="presentation">
                    <button class="nav-link" id="pills-favorite-tab" data-bs-toggle="pill" data-bs-target="#pills-favorite" type="button" role="tab" aria-controls="pills-favorite" aria-selected="false">
                      <i class="fas fa-history"></i> Fund History
                    </button>
                  </li>
                </ul>
              </div>

              <div class="tab-content tab_wrap" id="pills-tabContent">
                <div class="tab-pane fade show active" id="pills-order" role="tabpanel" aria-labelledby="pills-order-tab">
                  <div class="gateway-shell">
                    <div class="gateway-quick-grid" id="gatewayQuickGrid">
                      <button type="button" class="gateway-quick-item is-active" data-alias="binance_pay">
                        <span class="logo" style="background: linear-gradient(135deg, rgba(246, 194, 60, 0.2), rgba(246, 194, 60, 0.08)); color:#f0b90b;">B</span>
                        <span class="meta"><strong>Binance</strong><span>Quick select</span></span>
                      </button>
                      <button type="button" class="gateway-quick-item" data-alias="cryptomus">
                        <span class="logo" style="background: linear-gradient(135deg, rgba(17, 24, 39, 0.12), rgba(17, 24, 39, 0.04)); color:#111827;">C</span>
                        <span class="meta"><strong>Cryptomus</strong><span>Quick select</span></span>
                      </button>
                      <button type="button" class="gateway-quick-item" data-alias="heleket">
                        <span class="logo" style="background: linear-gradient(135deg, rgba(255, 57, 57, 0.16), rgba(255, 57, 57, 0.06)); color:#ff3838;">H</span>
                        <span class="meta"><strong>Heleket</strong><span>Quick select</span></span>
                      </button>
                      <button type="button" class="gateway-quick-item" data-alias="bangladesh">
                        <span class="logo" style="background: linear-gradient(135deg, rgba(0, 168, 89, 0.16), rgba(0, 168, 89, 0.06)); color:#008a4b;">BD</span>
                        <span class="meta"><strong>BD</strong><span>Quick select</span></span>
                      </button>
                      <button type="button" class="gateway-quick-item" data-alias="bkash_nagad_rocket">
                        <span class="logo" style="background: linear-gradient(135deg, rgba(233, 28, 101, 0.16), rgba(233, 28, 101, 0.06)); color:#e91c65;">Bk</span>
                        <span class="meta"><strong>BKash</strong><span>Quick select</span></span>
                      </button>
                      <button type="button" class="gateway-quick-item" data-alias="phonepe">
                        <span class="logo" style="background: linear-gradient(135deg, rgba(108, 57, 192, 0.18), rgba(108, 57, 192, 0.06)); color:#6c39c0;">P</span>
                        <span class="meta"><strong>Phonepe</strong><span>Quick select</span></span>
                      </button>
                      <button type="button" class="gateway-quick-item" data-alias="bybit_pay">
                        <span class="logo" style="background: linear-gradient(135deg, rgba(42, 47, 66, 0.16), rgba(42, 47, 66, 0.06)); color:#2a2f42;">By</span>
                        <span class="meta"><strong>ByBit</strong><span>Quick select</span></span>
                      </button>
                      <button type="button" class="gateway-quick-item" data-alias="gcash_maya">
                        <span class="logo" style="background: linear-gradient(135deg, rgba(0, 94, 255, 0.16), rgba(0, 94, 255, 0.06)); color:#005eff;">G/M</span>
                        <span class="meta"><strong>GCash/Maya</strong><span>Quick select</span></span>
                      </button>
                      <button type="button" class="gateway-quick-item" data-alias="visa">
                        <span class="logo" style="background: linear-gradient(135deg, rgba(0, 91, 187, 0.16), rgba(0, 91, 187, 0.06)); color:#005bbb;">V</span>
                        <span class="meta"><strong>Visa</strong><span>Quick select</span></span>
                      </button>
                    </div>

                    <div class="form-group mb-0">
                      <label for="gateway_alias" class="control-label">Method</label>
                      <select class="form-control" id="gateway_alias" name="gateway_alias">
                        <optgroup label="Crypto Payment">
                          <option value="binance_pay">Binance Pay [5% Bonus]</option>
                          <option value="cryptomus">Cryptomus - USDT | BTC | BCH | ETH | LTC + More [5% Bonus]</option>
                          <option value="heleket">Heleket - USDT | BTC | BCH | ETH | LTC + More [5% Bonus]</option>
                          <option value="bybit_pay">Bybit Pay - [Auto Pay] - Min 1$ [5% Bonus]</option>
                        </optgroup>
                        <optgroup label="Card Payment">
                          <option value="visa">Credit Card / Debit Card ~ Visa - Mastercard - Amex [5% Fees Applied]</option>
                        </optgroup>
                        <optgroup label="Local Payment">
