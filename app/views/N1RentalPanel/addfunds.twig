{% include 'footer.twig' %}

<div class="floating-support">
  <a href="https://wa.me/{{ whatsappnumber }}" target="_blank" rel="noopener noreferrer" aria-label="Contact support on WhatsApp">
    <i class="fab fa-whatsapp"></i>
  </a>
