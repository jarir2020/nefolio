<script>
  var paymentMethods = {{ site["paymentMethodsJSON"]|raw }};
  var bonusRateRules = {{ site["bonusRatesJSON"]|raw }};
  var globalDollarRate = parseFloat({{ site["dollarRate"] }});
  const addfundsRoute = "/addfunds";
  const gatewayCatalog = {
    binance_pay: { label: "Binance Pay [5% Bonus]" },
    cryptomus: { label: "Cryptomus - USDT | BTC | BCH | ETH | LTC + More [5% Bonus]" },
    heleket: { label: "Heleket - USDT | BTC | BCH | ETH | LTC + More [5% Bonus]" },
    bybit_pay: { label: "Bybit Pay - [Auto Pay] - Min 1$ [5% Bonus]" },
    visa: { label: "Credit Card / Debit Card ~ Visa - Mastercard - Amex [5% Fees Applied]" },
    bangladesh: { label: "বিকাশ - নগদ - রকেট [ For Bangladeshi User ]" },
    bkash_nagad_rocket: { label: "বিকাশ / নগদ / রকেট / উপায় + More [ For Bangladeshi User ]" },
    phonepe: { label: "PhonePe - For Indian User [Auto Pay] - 10% Fees Applied" },
    gcash_maya: { label: "GCash / Maya / Bank ~ Philippines [Manual] Min 1$" }
  };

  function getSelectedMethodData(methodId) {
    if (!paymentMethods || !paymentMethods[methodId] || !paymentMethods[methodId][0]) {
      return null;
    }
    return paymentMethods[methodId][0];
  }

  function getMethodRate(methodData) {
    if (!methodData) {
      return 1;
    }

    var rate = parseFloat(methodData.exchange_rate);
    return isNaN(rate) || rate <= 0 ? 1 : rate;
  }

  function getActiveBonusRules() {
    if (Array.isArray(bonusRateRules) && bonusRateRules.length) {
      return bonusRateRules;
    }

    return [
      { range_from: 0, range_to: 99, bonus_percent: 0 },
      { range_from: 100, range_to: 999, bonus_percent: 3 },
      { range_from: 1000, range_to: 4999, bonus_percent: 5 },
      { range_from: 5000, range_to: 9999, bonus_percent: 7 },
      { range_from: 10000, range_to: 49999, bonus_percent: 8 },
      { range_from: 50000, range_to: null, bonus_percent: 20 }
    ];
  }

  function getBonusPercent(amount) {
    amount = parseFloat(amount);
    if (isNaN(amount)) {
      return 0;
    }

    var rules = getActiveBonusRules();
    for (var i = 0; i < rules.length; i++) {
      var rule = rules[i];
      var from = parseFloat(rule.range_from);
      var to = rule.range_to === null || rule.range_to === "" ? null : parseFloat(rule.range_to);
      var percent = parseFloat(rule.bonus_percent);

      if (isNaN(from)) {
        continue;
      }

      if (amount >= from && (to === null || amount <= to)) {
        return isNaN(percent) ? 0 : percent;
      }
    }

    return 0;
  }

  function getBonusAmount(amount) {
    var bonusPercent = getBonusPercent(amount);
    return amount + (amount * (bonusPercent / 100));
  }

  function getActiveMethodId() {
    var methodId = $("#payment_type").val();
    if (methodId) {
      return methodId;
    }

    if (paymentMethods && Object.keys(paymentMethods).length) {
      return Object.keys(paymentMethods)[0];
    }

    return 0;
  }

  function preparePrice(t) {
    var n = 2;
    t = $.trim(t.toString().replace(",", "."));
    var r = t.split(".");
    if (r[1] !== undefined) {
      r[1] = r[1].replace(/0+$/g, "");
      if (r[1].length > n) {
        n = r[1].length > 2 ? 2 : r[1].length;
      }
    }
    t = parseFloat(t);
    t = t.toFixed(n);
    if (t >= 1000) {
      t = t.toString().replace(/(\d)(?=(\d\d\d)+([^\d]|$))/g, "$1");
    }
    return parseFloat(t).toFixed(n);
  }

  function formatDisplayAmount(value) {
    var formatted = preparePrice(value);
    formatted = formatted.replace(/\.00$/, "");
    formatted = formatted.replace(/(\.\d)0$/, "$1");
    return formatted;
  }

  function setActiveGateway(aliasKey) {
    $("#gatewayQuickGrid .gateway-quick-item").removeClass("is-active");
    $("#gatewayQuickGrid .gateway-quick-item[data-alias='" + aliasKey + "']").addClass("is-active");
  }

  function syncAliasSelection(aliasKey) {
    if (!gatewayCatalog[aliasKey]) {
      aliasKey = "binance_pay";
    }

    $("#gateway_alias").val(aliasKey);
    setActiveGateway(aliasKey);
  }

  function isLocalGateway(aliasKey) {
    return aliasKey === "bangladesh" || aliasKey === "bkash_nagad_rocket" || aliasKey === "phonepe" || aliasKey === "gcash_maya";
  }

  function syncCurrencyConverter(forceHide) {
    var aliasKey = $("#gateway_alias").val() || "binance_pay";
    var shouldShowConverter = !forceHide && isLocalGateway(aliasKey);
    var methodData = getSelectedMethodData(getActiveMethodId());
    var rate = !isNaN(globalDollarRate) && globalDollarRate > 0 ? globalDollarRate : getMethodRate(methodData);
    var usdValue = parseFloat($("#usdAmount").val());
    var bonusPercent = getBonusPercent(usdValue);
    var bonusAmount = isNaN(usdValue) ? 0 : getBonusAmount(usdValue);
    var bonusValue = isNaN(usdValue) ? 0 : bonusAmount - usdValue;

    if (!shouldShowConverter) {
      $("#currencyConverterWrap").hide();
      return;
    }

    $("#currencyConverterWrap").show();
    $("#exchangeRateLabel").text("1 USD = " + preparePrice(rate) + " BDT");
    $("#rateNote").text("1 USD = " + preparePrice(rate) + " BDT | Bonus tier: " + bonusPercent + "%");

    if (!isNaN(usdValue)) {
      $("#paymentAmount").val(preparePrice(usdValue));
      $("#bdtAmount").val(preparePrice(usdValue * rate));
      $("#totalAmountLabel").text(preparePrice(bonusAmount) + " USD");
      if (bonusValue > 0) {
        $("#bonusBreakdownNote").text("For example: " + formatDisplayAmount(bonusAmount) + "USD = " + formatDisplayAmount(usdValue) + " USD + " + formatDisplayAmount(bonusValue) + " USD");
      } else {
        $("#bonusBreakdownNote").text("");
      }
    } else {
      $("#paymentAmount").val("");
      $("#bdtAmount").val("");
      $("#totalAmountLabel").text("0.00 USD");
      $("#bonusBreakdownNote").text("");
    }
  }

  function addfundsInit() {
    var selectedMethod = getActiveMethodId();
    var methodData = getSelectedMethodData(selectedMethod);

    if (!methodData) {
      $("#addfunds_fields").html('<div class="method-box"><div class="panel-body border-solid border-rounded">No payment gateway is available right now.</div></div>');
      $("#fee_fields").empty();
      return;
    }

    $.ajax({
      url: addfundsRoute,
      data: "action=getForm&selectedMethod=" + selectedMethod,
      type: "POST",
      dataType: "json",
      success: function (json) {
        if (json.success === true) {
          var methodInstruction = "";
          if (methodData.instructions && methodData.instructions.length > 0) {
            methodInstruction =
              '<div class="method-box">' +
              '<label class="control-label">Instructions</label>' +
              '<div class="panel-body border-solid border-rounded">' +
              methodData.instructions +
              "</div></div>";
          }
          $("#addfunds_fields").html(methodInstruction + json.content);
          extraFeeInit(selectedMethod);
          syncCurrencyConverter();
        }
      }
    });
  }

  function extraFeeInit(method) {
    var methodData = getSelectedMethodData(method);
    var fee = methodData ? parseFloat(methodData.fee).toFixed(2) : "0.00";
    var fields = $("#fee_fields");
    var amount = parseFloat($("#usdAmount").val());

    if (parseFloat(fee) > 0) {
      fields.html(
        '<div class="fee-grid">' +
        '<div class="form-group">' +
        '<label class="control-label">Extra fee</label>' +
        '<input type="text" class="form-control" id="methodExtraFee" disabled value="' + (isNaN(amount) ? "0.00" : preparePrice(amount * (parseFloat(fee) / 100))) + '"/>' +
        "</div>" +
        '<div class="form-group">' +
        '<label class="control-label">Total Amount</label>' +
        '<input type="text" id="totalAmount" class="form-control" disabled value="' + (isNaN(amount) ? "0.00" : preparePrice(amount + (amount * (parseFloat(fee) / 100)))) + '" />' +
        "</div></div>"
      );
    } else {
      fields.empty();
    }
  }

  $(document).ready(function () {
    if (!$("#payment_type").val() || $("#payment_type").val() === "0") {
      var methodKeys = paymentMethods ? Object.keys(paymentMethods) : [];
      if (paymentMethods && paymentMethods["42"]) {
        $("#payment_type").val("42");
      } else if (methodKeys.length) {
        $("#payment_type").val(methodKeys[0]);
      }
    }

    syncAliasSelection($("#gateway_alias").val() || "binance_pay");
    syncCurrencyConverter();

    $(document).on("click", "#usdQuickSelect button", function () {
      $("#usdQuickSelect button").removeClass("is-active");
      $(this).addClass("is-active");
      $("#usdAmount").val($(this).data("amount")).trigger("input");
    });

    $(document).on("input", "#usdAmount", function () {
      var selectedMethod = getActiveMethodId();
      var methodData = getSelectedMethodData(selectedMethod);
      var amount = parseFloat($(this).val());
      var rate = isLocalGateway($("#gateway_alias").val() || "binance_pay") && !isNaN(globalDollarRate) && globalDollarRate > 0 ? globalDollarRate : getMethodRate(methodData);

      if (isNaN(amount)) {
        $("#paymentAmount").val("");
        $("#bdtAmount").val("");
        $("#totalAmountLabel").text("0.00 USD");
        $("#bonusBreakdownNote").text("");
        $("#methodExtraFee").val("0.00");
        $("#totalAmount").val("0.00");
        return;
      }

      var bonusPercent = getBonusPercent(amount);
      var bonusAmount = getBonusAmount(amount);
      var bonusValue = bonusAmount - amount;
      $("#paymentAmount").val(preparePrice(amount));
      $("#bdtAmount").val(preparePrice(amount * rate));
      $("#totalAmountLabel").text(preparePrice(bonusAmount) + " USD");
      $("#rateNote").text("1 USD = " + preparePrice(rate) + " BDT | Bonus tier: " + bonusPercent + "%");
      if (bonusValue > 0) {
        $("#bonusBreakdownNote").text("For example: " + formatDisplayAmount(bonusAmount) + "USD = " + formatDisplayAmount(amount) + " USD + " + formatDisplayAmount(bonusValue) + " USD");
      } else {
        $("#bonusBreakdownNote").text("");
      }

      if (!methodData) {
        return;
      }

      var feePercentage = parseFloat(methodData.fee);
      var feeInput = $("#methodExtraFee");
      var totalAmountInput = $("#totalAmount");
      var fee = amount * (feePercentage / 100);

      if (feeInput.length && totalAmountInput.length) {
        feeInput.val(preparePrice(fee));
        totalAmountInput.val(preparePrice(amount + fee));
      }
    });

    $(document).on("click", "#gatewayQuickGrid .gateway-quick-item", function () {
      var aliasKey = $(this).data("alias");
      syncAliasSelection(aliasKey);
      $("#gateway_alias").trigger("change");
    });

    $("#gateway_alias").change(function () {
      syncAliasSelection($(this).val());
      syncCurrencyConverter();
    });

    addfundsInit();
  });

  $("#addfundsForm").submit(function (e) {
    var method = getActiveMethodId();
    if (method == "24" || method == "45") {
      return true;
    }

    if ($("#usdAmount").length) {
      $("#paymentAmount").val(preparePrice($("#usdAmount").val()));
    }

    e.preventDefault();

    $.ajax({
      url: addfundsRoute,
      data: $(this).serialize(),
      type: "POST",
      dataType: "json",
      success: function (json) {
        if (json.binance === true) {
          $(".addfunds-shell, #addFundPolicyWrap").hide();
          $("#binance-qr-modal").remove();
          $("body").append(json.html);
          $("#binance-qr-modal").modal("show");
          return;
        }

        if (json.bybit === true) {
          $(".addfunds-shell, #addFundPolicyWrap").hide();
          $("#bybit-qr-modal").remove();
          $("body").append(json.html);
          $("#bybit-qr-modal").modal("show");
          return;
        }

        if (json.success === true) {
          $("#formSubmitResponseMessage").html(
            '<div class="alert alert-success alert-dismissible fade show mt-3" role="alert">' +
            json.message +
            '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
            '<span aria-hidden="true">×</span></button></div>'
          );
          $("#formSubmitResponseContent").html(json.content);
        } else {
          $("#formSubmitResponseMessage").html(
            '<div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">' +
            json.message +
            '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
            '<span aria-hidden="true">×</span></button></div>'
          );
        }
      }
    });
  });

  $(document).on("hidden.bs.modal", "#binance-qr-modal", function () {
    $(".addfunds-shell, #addFundPolicyWrap").show();
    $("#binance-qr-modal").remove();
  });

  $(document).on("hidden.bs.modal", "#bybit-qr-modal", function () {
    $(".addfunds-shell, #addFundPolicyWrap").show();
    $("#bybit-qr-modal").remove();
  });
</script>
