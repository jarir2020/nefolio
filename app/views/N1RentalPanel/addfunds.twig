{% include 'header.twig' %}
<style>
  .addfunds-shell {
    padding: 24px 0 40px;
    background:
      linear-gradient(180deg, #eef4ff 0%, #f7f9ff 100%);
  }

  .addfunds-shell .container-fluid {
    max-width: 1180px;
    margin: 0 auto;
  }

  .card_v2 {
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 22px;
    box-shadow: 0 12px 34px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }

  .tutorial-card .card-body,
  .gateway-card .card-body,
  .policy-card .card-body,
  .main-card .card-body {
    padding: 22px;
  }

  .section-title {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 18px;
  }

  .section-title .eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6b7280;
    font-weight: 700;
  }

  .section-title h2,
  .section-title h3 {
    margin: 0;
    font-weight: 800;
    color: #0f172a;
  }

  .title-line {
    width: 88px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, #ff9f1c, #2a2a72);
  }

  .lead-copy {
    color: #475569;
    line-height: 1.8;
    margin-bottom: 18px;
  }

  .support-alert {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(42, 42, 114, 0.08), rgba(255, 164, 0, 0.08));
    border: 1px solid rgba(42, 42, 114, 0.12);
    color: #1e293b;
    margin-bottom: 18px;
  }

  .support-alert i {
    color: #2a2a72;
    margin-top: 2px;
    font-size: 18px;
  }

  .premium-balance-card {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    padding: 18px 20px;
    background: linear-gradient(135deg, #0f172a 0%, #2a2a72 55%, #ff9f1c 130%);
    color: #fff;
    margin-bottom: 18px;
    min-height: 126px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .premium-balance-card::after {
    content: "";
    position: absolute;
    inset: auto -30px -30px auto;
    width: 180px;
    height: 180px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
  }

  .balance-copy .label {
    display: inline-block;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.82;
    margin-bottom: 8px;
  }

  .balance-copy .amount {
    margin: 0;
    font-size: 34px;
    font-weight: 800;
    line-height: 1;
  }

  .balance-copy .subline {
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.82);
    font-size: 14px;
  }

  .balance-icon {
    width: 74px;
    height: 74px;
    display: grid;
    place-items: center;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
    font-size: 30px;
    z-index: 1;
    position: relative;
    flex: 0 0 auto;
  }

  .video-frame {
    border-radius: 20px;
    overflow: hidden;
    min-height: 260px;
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.92), rgba(42, 42, 114, 0.9)),
      radial-gradient(circle at top right, rgba(255, 164, 0, 0.55), transparent 34%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .video-frame::before {
    content: "";
    position: absolute;
    inset: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
  }

  .video-copy {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    max-width: 320px;
    padding: 24px;
  }

  .video-play {
    width: 82px;
    height: 82px;
    margin: 0 auto 18px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #ff9f1c, #f97316);
    box-shadow: 0 18px 35px rgba(249, 115, 22, 0.35);
    font-size: 30px;
  }

  .video-copy h4 {
    margin: 0 0 8px;
    font-weight: 800;
  }

  .video-copy p {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
  }

  .tab_btn_wrap {
    gap: 0;
    flex-wrap: wrap;
    margin-top: 0;
    background: #f0f4ff;
    padding: 8px;
    border-radius: 16px;
  }

  .tab_btn_wrap .nav-link {
    border: 0;
    border-radius: 14px;
    padding: 14px 18px;
    background: transparent;
    color: #1f2b4d;
    font-weight: 800;
    box-shadow: none;
    flex: 1 1 0;
    min-height: 56px;
  }

  .tab_btn_wrap .nav-link.active {
    background: linear-gradient(135deg, #1280ff 0%, #19a0f4 100%);
    color: #fff;
    box-shadow: 0 12px 24px rgba(18, 128, 255, 0.24);
  }

  .tab_wrap {
    padding-top: 18px;
  }

  .gateway-shell {
    display: grid;
    gap: 14px;
    margin-bottom: 16px;
  }

  .gateway-quick-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .gateway-quick-item {
    width: 100%;
    min-height: 94px;
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    padding: 14px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 8px;
    text-align: center;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
  }

  .gateway-quick-item:hover,
  .gateway-quick-item.is-active {
    border-color: rgba(118, 84, 255, 0.55);
    box-shadow: 0 14px 28px rgba(118, 84, 255, 0.14);
    transform: translateY(-2px);
    background: linear-gradient(180deg, #faf8ff 0%, #ffffff 100%);
  }

  .gateway-quick-item .logo {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    object-fit: contain;
    background: #f8fafc;
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.06);
    font-size: 14px;
    font-weight: 800;
  }

  .gateway-quick-item .meta {
    min-width: 0;
  }

  .gateway-quick-item .meta strong {
    display: block;
    color: #0f172a;
    font-size: 15px;
    line-height: 1.25;
    font-weight: 700;
  }

  .gateway-quick-item .meta span {
    display: none;
  }

  @media (max-width: 767px) {
    .gateway-quick-item {
      min-height: 78px;
      padding: 10px;
      gap: 0;
    }

    .gateway-quick-item .meta {
      display: none;
    }

    .gateway-quick-item .logo {
      margin: 0;
    }

    .bonus-rates-grid {
      grid-template-columns: 1fr;
    }

    .bonus-rate-card .range,
    .bonus-rate-card .percent {
      font-size: 16px;
    }
  }

  .converter-panel {
    margin-bottom: 18px;
    padding: 18px;
    border-radius: 18px;
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: 0 10px 26px rgba(15, 23, 42, 0.05);
  }

  .converter-panel .converter-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .converter-panel .converter-head h4 {
    margin: 0;
    font-size: 17px;
    font-weight: 800;
    color: #0f172a;
  }

  .converter-panel .rate-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 999px;
    background: #fff;
    color: #2a2a72;
    font-weight: 700;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
    white-space: nowrap;
  }

  .quick-amounts {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 18px;
  }

  .quick-amounts button {
    border: 1px solid rgba(148, 163, 184, 0.28);
    background: #fff;
    color: #2f6fd6;
    border-radius: 14px;
    min-width: 72px;
    height: 46px;
    padding: 0 16px;
    font-weight: 800;
    box-shadow: 0 8px 16px rgba(15, 23, 42, 0.05);
    transition: all 0.18s ease;
  }

  .quick-amounts button:hover,
  .quick-amounts button.is-active {
    background: linear-gradient(135deg, #6734f6, #8d55ff);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 14px 24px rgba(103, 52, 246, 0.22);
  }

  .converter-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    align-items: end;
  }

  .converter-grid .swap-icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 14px;
    background: #fff;
    color: #2a2a72;
    font-size: 18px;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
    margin-bottom: 2px;
  }

  .converter-grid .form-control[readonly] {
    background: #edf5ff;
    cursor: not-allowed;
  }

  .converter-grid .form-group {
    min-width: 0;
  }

  .rate-summary {
    margin-top: 16px;
    border-radius: 18px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background: linear-gradient(180deg, #ffffff 0%, #fafcff 100%);
    padding: 16px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
  }

  .rate-summary .copy {
    display: grid;
    gap: 4px;
  }

  .rate-summary .copy .eyebrow {
    color: #64748b;
    font-size: 12px;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .rate-summary .copy .value {
    color: #0f172a;
    font-size: 34px;
    font-weight: 900;
    line-height: 1;
  }

  .rate-summary .badge-note {
    flex: 0 0 auto;
    border-radius: 12px;
    padding: 10px 14px;
    background: rgba(34, 197, 94, 0.12);
    color: #16a34a;
    font-weight: 800;
    font-size: 14px;
    text-align: center;
  }

  .rate-summary .breakdown-note {
    flex: 0 0 100%;
    margin-top: 2px;
    color: #64748b;
    font-size: 14px;
    font-weight: 700;
    text-align: left;
  }

  .converter-fee-fields {
    margin-top: 16px;
  }

  .pay-action {
    margin-top: 18px;
    border: 0;
    min-height: 56px;
    border-radius: 14px;
    background: linear-gradient(90deg, #5b25ef 0%, #19b5d8 100%);
    font-size: 17px;
    font-weight: 800;
    box-shadow: 0 18px 34px rgba(25, 181, 216, 0.2);
  }

  .pay-action:hover,
  .pay-action:focus,
  .pay-action:active {
    background: linear-gradient(90deg, #5b25ef 0%, #19b5d8 100%) !important;
    border: 0 !important;
    box-shadow: 0 18px 34px rgba(25, 181, 216, 0.2) !important;
  }

  .form-control,
  .form-select {
    min-height: 48px;
    border-radius: 14px;
    border-color: rgba(15, 23, 42, 0.12);
    box-shadow: none !important;
  }

  #addfunds_fields .form-group + .form-group {
    margin-top: 14px;
  }

  .method-box {
    margin-top: 14px;
    border-radius: 16px;
    background: #f8fafc;
    border: 1px solid rgba(15, 23, 42, 0.08);
    padding: 16px;
  }

  .method-box .panel-body {
    color: #334155;
    line-height: 1.75;
    word-break: break-word;
  }

  .fee-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .history-table {
    overflow-x: auto;
  }

  .history-table table {
    margin-bottom: 0;
  }

  .history-table thead th {
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    color: #dc2626;
    font-weight: 800;
    white-space: nowrap;
  }

  .history-table tbody td {
    vertical-align: middle;
    white-space: nowrap;
    color: #334155;
  }

  .info-card .card-header,
  .policy-card .card-header {
    background: linear-gradient(135deg, #0f172a, #2a2a72);
    color: #fff;
    border-bottom: 0;
    padding: 18px 24px;
  }

  .header-title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 800;
  }

  .header-title .icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.12);
    display: grid;
    place-items: center;
    flex: 0 0 auto;
  }

  .gateway-copy {
    color: #475569;
    line-height: 1.85;
  }

  .policy-card ul {
    padding-left: 20px;
    margin: 0;
    color: #334155;
    line-height: 1.8;
  }

  .policy-card li + li {
    margin-top: 8px;
  }

  .bonus-rates-box {
    margin-bottom: 16px;
  }

  .bonus-rates-box .bonus-rates-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 16px;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
  }

  .bonus-rates-box .bonus-rates-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    color: #0f172a;
  }

  .bonus-rates-box .bonus-rates-title i {
    color: #ef4444;
    font-size: 16px;
  }

  .bonus-rates-toggle {
    border: 0;
    border-radius: 12px;
    padding: 10px 18px;
    background: #e8efff;
    color: #2f6fd6;
    font-weight: 700;
    box-shadow: none;
  }

  .bonus-rates-collapse {
    margin-top: 12px;
    padding: 16px;
    border-radius: 18px;
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.08);
  }

  .bonus-rates-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .bonus-rate-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 14px;
    background: #fff;
    border: 1px solid rgba(226, 232, 240, 1);
    box-shadow: 0 4px 10px rgba(15, 23, 42, 0.04);
    min-height: 62px;
  }

  .bonus-rate-card .range {
    font-size: 18px;
    font-weight: 800;
    color: #6b7280;
    letter-spacing: -0.02em;
  }

  .bonus-rate-card .percent {
    min-width: 62px;
    padding: 8px 14px;
    border-radius: 12px;
    background: #f3f4fb;
    color: #27324d;
    font-size: 18px;
    font-weight: 800;
    text-align: center;
  }

  .bonus-rates-empty {
    padding: 12px 2px 2px;
    color: #64748b;
    font-size: 14px;
  }

  .content-stack {
    display: grid;
    gap: 22px;
  }

  .addfunds-mock-ui .policy-card {
    display: none;
  }

  .addfunds-mock-ui .col-lg-7 {
    flex: 0 0 100%;
    max-width: 100%;
  }

  .addfunds-mock-ui #usdAmountWrap {
    display: none;
  }

  .addfunds-mock-ui .main-card .card-body {
    padding-bottom: 26px;
  }

  .floating-support {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 9999;
  }

  .floating-support a {
    width: 58px;
    height: 58px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    box-shadow: 0 16px 30px rgba(18, 140, 126, 0.35);
    text-decoration: none;
    font-size: 28px;
  }

  @media (max-width: 991px) {
    .gateway-quick-grid,
    .converter-grid {
      grid-template-columns: 1fr;
    }

    .converter-panel .converter-head,
    .rate-summary {
      flex-direction: column;
      align-items: flex-start;
    }

    .premium-balance-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .balance-icon {
      width: 62px;
      height: 62px;
      font-size: 26px;
    }

    .addfunds-mock-ui .col-lg-7 {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .fee-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .addfunds-shell {
      padding: 24px 0 28px;
    }

    .main-card .card-body,
    .policy-card .card-body,
    .tutorial-card .card-body,
    .gateway-card .card-body {
      padding: 14px;
    }

    .main-card .card-body {
      padding-top: 18px;
    }

    .tab_btn_wrap {
      gap: 8px;
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 4px;
      -webkit-overflow-scrolling: touch;
    }

    .tab_btn_wrap .nav-link {
      padding: 9px 14px;
      font-size: 14px;
      white-space: nowrap;
      flex: 0 0 auto;
    }

    .gateway-shell {
      gap: 10px;
      margin-bottom: 14px;
    }

    .gateway-quick-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .gateway-quick-item {
      min-height: 78px;
      padding: 10px 8px;
      justify-content: center;
      border-radius: 14px;
      flex-direction: column;
    }

    .gateway-quick-item .logo {
      width: 30px;
      height: 30px;
      border-radius: 10px;
      font-size: 12px;
    }

    .gateway-quick-item .meta {
      display: block;
    }

    .gateway-quick-item .meta strong {
      font-size: 13px;
      text-align: center;
    }

    .form-group > label,
    .control-label {
      font-size: 14px;
      margin-bottom: 6px;
    }

    .form-control,
    .form-select {
      min-height: 44px;
      border-radius: 12px;
    }

    .converter-panel {
      padding: 14px;
      border-radius: 18px;
      margin-bottom: 14px;
    }

    .converter-panel .converter-head h4 {
      font-size: 15px;
    }

    .converter-panel .rate-badge {
      padding: 7px 10px;
      font-size: 12px;
    }

    .quick-amounts {
      gap: 8px;
      margin-bottom: 14px;
    }

    .quick-amounts button {
      min-width: 48px;
      height: 40px;
      padding: 0 10px;
      border-radius: 12px;
      font-size: 13px;
    }

    .converter-grid {
      gap: 10px;
    }

    .converter-grid .swap-icon {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      font-size: 16px;
      align-self: center;
      margin-bottom: 0;
    }

    .rate-summary {
      padding: 14px;
      gap: 10px;
    }

    .rate-summary .copy .value {
      font-size: 26px;
    }

    .rate-summary .badge-note {
      width: 100%;
      font-size: 13px;
      padding: 10px 12px;
    }

    .rate-summary .breakdown-note {
      font-size: 13px;
      line-height: 1.45;
    }

    .bonus-rates-box .bonus-rates-head {
      padding: 12px 14px;
      border-radius: 14px;
    }

    .bonus-rates-toggle {
      padding: 8px 12px;
      font-size: 13px;
    }

    .bonus-rates-collapse {
      padding: 12px 14px;
      border-radius: 14px;
    }

    .bonus-rate-item {
      padding: 8px 0;
    }

    .pay-action {
      min-height: 50px;
      font-size: 16px;
      margin-top: 14px;
      border-radius: 12px;
    }

    .method-box {
      padding: 14px;
      border-radius: 14px;
    }

    .policy-card {
      display: none;
    }

    .content-stack {
      gap: 16px;
    }
  }
</style>

  <div class="addfunds-shell addfunds-mock-ui">
  <div class="container-fluid">
    <div class="content-stack">
      <div class="row g-4">
        <div class="col-lg-7">
          <div class="card_v2 main-card h-100">
            <div class="card-body">
              <div id="newOrderTabsWrap">
                <ul class="nav nav-pills tab_btn_wrap mb-0" id="pills-tab" role="tablist">
                  <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="pills-order-tab" data-bs-toggle="pill" data-bs-target="#pills-order" type="button" role="tab" aria-controls="pills-order" aria-selected="true">
                      <i class="far fa-credit-card"></i> Add Fund
                    </button>
                  </li>
                  <li class="nav-item" role="presentation">
                    <button class="nav-link" id="pills-favorite-tab" data-bs-toggle="pill" data-bs-target="#pills-favorite" type="button" role="tab" aria-controls="pills-favorite" aria-selected="false">
                      <i class="fas fa-history"></i> Fund History
                    </button>
                  </li>
