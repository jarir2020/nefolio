<script>
  var paymentMethods = {{ site["paymentMethodsJSON"]|raw }};
  var defaultPaymentMethodLogo = "/img/admin/payment-methods.svg";
  var bonusRateRules = {{ site["bonusRatesJSON"]|raw }};
  var globalDollarRate = parseFloat({{ site["dollarRate"] }});
  const addfundsRoute = "/addfunds";
  const defaultGatewayLogo = "/img/admin/payment-methods.svg";

  function buildGatewayTileData(methodData, index) {
    var alias = getMethodAlias(methodData) || "method_" + methodData.id;
    var shortName = methodData.tile_label || methodData.short_name || methodData.name || "Gateway";
    var methodName = methodData.method_name || methodData.name || shortName || "Gateway";
    var logo = getMethodLogoUrl(methodData);

    // Generate a stable hue from the method id for the tile background
    var hue = ((methodData.id * 47) % 360);
    var bg = "linear-gradient(135deg, hsla(" + hue + ", 40%, 60%, 0.16), hsla(" + hue + ", 30%, 50%, 0.06))";
    var color = "hsl(" + hue + ", 35%, 35%)";
    var badge = shortName.charAt(0).toUpperCase();

    return {
      alias: alias,
      label: shortName,
      methodName: methodName,
      shortName: shortName,
      badge: badge,
      bg: bg,
      color: color,
      logo: logo
    };
  }

  function getDynamicGatewayTiles() {
    var methods = getPaymentMethodList();
    var tiles = [];
    for (var i = 0; i < methods.length; i++) {
      var tile = buildGatewayTileData(methods[i], i);
      tiles.push(tile);
    }
    return tiles;
  }

  function escapeHtml(value) {
    return $("<div>").text(value == null ? "" : String(value)).html();
  }

  function getSelectedMethodData(methodId) {
    if (!paymentMethods || !paymentMethods[methodId] || !paymentMethods[methodId][0]) {
      return null;
    }
    return paymentMethods[methodId][0];
  }

  function getPaymentMethodList() {
    var methods = [];

    if (!paymentMethods) {
      return methods;
    }

    var paymentMethodKeys = Object.keys(paymentMethods);
    for (var i = 0; i < paymentMethodKeys.length; i++) {
      var methodData = paymentMethods[paymentMethodKeys[i]] && paymentMethods[paymentMethodKeys[i]][0] ? paymentMethods[paymentMethodKeys[i]][0] : null;
      if (methodData) {
        methods.push(methodData);
      }
    }

    methods.sort(function (a, b) {
      var aPosition = parseInt(a.position, 10);
      var bPosition = parseInt(b.position, 10);
      if (isNaN(aPosition)) {
        aPosition = 0;
      }
      if (isNaN(bPosition)) {
        bPosition = 0;
      }

      if (aPosition !== bPosition) {
        return aPosition - bPosition;
      }

      var aId = parseInt(a.id, 10);
      var bId = parseInt(b.id, 10);
      if (isNaN(aId)) {
        aId = 0;
      }
      if (isNaN(bId)) {
        bId = 0;
      }

      return aId - bId;
    });

    return methods;
  }

  function getMethodLogoUrl(methodData) {
    if (!methodData || !methodData.logo) {
      return defaultGatewayLogo;
    }

    if (methodData.logo.indexOf("http://") === 0 || methodData.logo.indexOf("https://") === 0 || methodData.logo.indexOf("/") === 0) {
      return methodData.logo;
    }

    return "/" + methodData.logo.replace(/^\/+/, "");
  }

  function getMethodAlias(methodData) {
    if (!methodData || !methodData.callback) {
      return "";
    }

    return methodData.callback;
  }

  function findMethodByAlias(aliasKey) {
    var methods = getPaymentMethodList();
    for (var i = 0; i < methods.length; i++) {
      if (getMethodAlias(methods[i]) === aliasKey) {
        return methods[i];
      }
    }

    return null;
  }

  function getGatewayTileLogo(aliasKey) {
    var methodData = findMethodByAlias(aliasKey);
    if (methodData && methodData.logo) {
      return methodData.logo;
    }

    return "";
  }

  function getActiveTiles() {
    return getDynamicGatewayTiles();
  }

  function buildGatewayAliasSelect() {
    var activeTiles = getActiveTiles();
    var html = "";

    for (var i = 0; i < activeTiles.length; i++) {
      var tile = activeTiles[i];
      html += '<option value="' + escapeHtml(tile.alias) + '">' + escapeHtml(tile.methodName || tile.label) + '</option>';
    }

    $("#gateway_alias").html(html);
  }

  function renderGatewayQuickGrid() {
    var activeAlias = $("#gateway_alias").val() || "";
    var activeTiles = getActiveTiles();
    var html = "";

    if (activeTiles.length === 0) {
      $("#gatewayQuickGrid").html('<div class="text-center py-3 text-muted">No payment gateway is available right now.</div>');
      return;
    }

    // If the currently selected alias is no longer active, pick the first active tile
    var found = activeTiles.some(function (t) { return t.alias === activeAlias; });
    if (!found) {
      activeAlias = activeTiles[0].alias;
      var methodData = findMethodByAlias(activeAlias);
      if (methodData) {
        $("#payment_type").val(methodData.id);
        $("#gateway_alias").val(activeAlias);
      }
    }

    for (var i = 0; i < activeTiles.length; i++) {
      var tile = activeTiles[i];
      var tileLogo = getGatewayTileLogo(tile.alias);
      var isActive = tile.alias === activeAlias ? " is-active" : "";

      // Use shortName beside the logo on desktop; mobile CSS hides the label.
      var methodData = findMethodByAlias(tile.alias);
      var displayLabel = methodData && methodData.short_name ? methodData.short_name : tile.label;

      html +=
        '<button type="button" class="gateway-quick-item' + isActive + '" data-alias="' + escapeHtml(tile.alias) + '" data-method-id="' + escapeHtml(tile.alias) + '">' +
        '<span class="logo" style="background:' + tile.bg + ';color:' + tile.color + ';">' +
        (tileLogo ? '<img src="' + escapeHtml(tileLogo) + '" alt="' + escapeHtml(displayLabel) + '" onerror="this.onerror=null;this.src=\'' + defaultPaymentMethodLogo + '\';" style="width:100%;height:100%;object-fit:contain;">' : escapeHtml(tile.badge)) +
        '</span>' +
        '<span class="meta"><strong>' + escapeHtml(displayLabel) + '</strong></span>' +
        '</button>';
    }

    $("#gatewayQuickGrid").html(html);
  }

  function isMethodBonusEnabled(methodData) {
    return !!(methodData && methodData.bonus_ui_enabled);
  }

  function isDollarRateConversionEnabled(methodData) {
    return !!(methodData && methodData.converter_ui_enabled);
  }

  function getMethodRate(methodData) {
    if (!methodData) {
      return null;
    }

    var rate = parseFloat(methodData.exchange_rate);
    return isNaN(rate) || rate <= 0 ? null : rate;
  }

  function getActiveBonusRules(methodData) {
    var rules = [];

    if (methodData && Array.isArray(methodData.bonus_tiers) && methodData.bonus_tiers.length) {
      rules = methodData.bonus_tiers;
    } else if (methodData && Array.isArray(methodData.bonus_rules) && methodData.bonus_rules.length) {
      rules = methodData.bonus_rules;
    }

    if (!rules.length) {
      rules = [];
    }

    return rules.filter(function (rule) {
      if (typeof rule.is_active === "undefined") {
        return true;
      }
      return parseInt(rule.is_active, 10) === 1;
    });
  }

  function getBonusPercent(amount, methodData) {
    amount = parseFloat(amount);
    if (isNaN(amount)) {
      return 0;
    }

    var rules = getActiveBonusRules(methodData);
    for (var i = 0; i < rules.length; i++) {
      var rule = rules[i];
      var from = parseFloat(rule.range_from);
      var to = rule.range_to === null || rule.range_to === "" ? null : parseFloat(rule.range_to);
      var percent = parseFloat(rule.bonus_percent);

      if (isNaN(from)) {
        continue;
      }

      if (amount >= from && (to === null || amount <= to)) {
        return isNaN(percent) ? 0 : percent;
      }
    }

    return 0;
  }

  function getBonusAmount(amount, methodData) {
    var bonusPercent = getBonusPercent(amount, methodData);
    return amount + (amount * (bonusPercent / 100));
  }

  function getBonusValue(amount, methodData) {
    amount = parseFloat(amount);
    if (isNaN(amount) || !isMethodBonusEnabled(methodData)) {
      return 0;
    }

    return getBonusAmount(amount, methodData) - amount;
  }

  function getFeeAmount(amount, methodData) {
    amount = parseFloat(amount);
    if (isNaN(amount) || !methodData) {
      return 0;
    }

    var feePercent = parseFloat(methodData.fee);
    if (isNaN(feePercent) || feePercent <= 0) {
      return 0;
    }

    return amount * (feePercent / 100);
  }

  function getNetTotalAmount(amount, methodData) {
    amount = parseFloat(amount);
    if (isNaN(amount)) {
      return 0;
    }

    return amount + getBonusValue(amount, methodData) - getFeeAmount(amount, methodData);
  }

  function getActiveMethodId() {
    var methodId = $("#payment_type").val();
    if (methodId && methodId !== "0") {
      return methodId;
    }

    var methods = getPaymentMethodList();
    if (methods.length) {
      return methods[0].id;
    }

    return 0;
  }

  function preparePrice(t) {
    var n = 2;
    t = $.trim(t.toString().replace(",", "."));
    var r = t.split(".");
    if (r[1] !== undefined) {
      r[1] = r[1].replace(/0+$/g, "");
      if (r[1].length > n) {
        n = r[1].length > 2 ? 2 : r[1].length;
      }
    }
    t = parseFloat(t);
    t = t.toFixed(n);
    if (t >= 1000) {
      t = t.toString().replace(/(\d)(?=(\d\d\d)+([^\d]|$))/g, "$1");
    }
    return parseFloat(t).toFixed(n);
  }

  function formatDisplayAmount(value) {
    var formatted = preparePrice(value);
    formatted = formatted.replace(/\.00$/, "");
    formatted = formatted.replace(/(\.\d)0$/, "$1");
    return formatted;
  }

  function getMethodBonusStatusLabel(methodData) {
    return isMethodBonusEnabled(methodData) ? "On" : "Off";
  }

  function formatGatewayAmountRange(value) {
    if (value === null || value === undefined || value === "") {
      return "No limit";
    }

    return formatDisplayAmount(value) + " USD";
  }

  function buildGatewayBonusRuleText(methodData) {
    var rules = [];

    if (methodData && Array.isArray(methodData.bonus_tiers) && methodData.bonus_tiers.length) {
      rules = methodData.bonus_tiers;
    } else if (methodData && Array.isArray(methodData.bonus_rules) && methodData.bonus_rules.length) {
      rules = methodData.bonus_rules;
    }

    if (!rules.length) {
      return "";
    }

    var parts = [];
    for (var i = 0; i < rules.length; i++) {
      var rule = rules[i];
      if (rule && typeof rule.is_active !== "undefined" && parseInt(rule.is_active, 10) !== 1) {
        continue;
      }

      var fromAmount = formatGatewayAmountRange(rule.range_from);
      var toAmount = formatGatewayAmountRange(rule.range_to);
      var percent = parseFloat(rule.bonus_percent);
      if (isNaN(percent)) {
        percent = 0;
      }

      if (toAmount === "No limit") {
        parts.push(fromAmount + " and up: " + formatDisplayAmount(percent) + "%");
      } else {
        parts.push(fromAmount + " - " + toAmount + ": " + formatDisplayAmount(percent) + "%");
      }
    }

    return parts.join(" | ");
  }

  function formatBonusTierLabel(rule) {
    if (!rule) {
      return "";
    }

    var from = parseFloat(rule.range_from);
    if (isNaN(from)) {
      from = 0;
    }

    return "$" + formatDisplayAmount(from) + "+";
  }

  function buildBonusRatesGrid(methodData) {
    var rules = getActiveBonusRules(methodData);
    var cards = [];

    for (var i = 0; i < rules.length; i++) {
      var rule = rules[i];
      if (!rule) {
        continue;
      }

      var percent = parseFloat(rule.bonus_percent);
      if (isNaN(percent) || percent <= 0) {
        continue;
      }

      cards.push(
        '<div class="bonus-rate-card">' +
        '<span class="range">' + escapeHtml(formatBonusTierLabel(rule)) + '</span>' +
        '<span class="percent">' + escapeHtml(formatDisplayAmount(percent)) + '%</span>' +
        '</div>'
      );
    }

    if (!cards.length) {
      return '<div class="bonus-rates-empty">No bonus rates available for this gateway.</div>';
    }

    return '<div class="bonus-rates-grid">' + cards.join("") + '</div>';
  }

  function buildGatewayBonusDetails(methodData) {
    if (!methodData) {
      return "";
    }

    var details = [];
    var bonusEnabled = isMethodBonusEnabled(methodData);
    var bonusStatus = bonusEnabled ? "On" : "Off";
    var feePercent = parseFloat(methodData.fee);
    var bonusPercent = parseFloat(methodData.bonus_percentage);
    var bonusStartAmount = parseFloat(methodData.bonus_start_amount);

    if (bonusEnabled) {
      details.push("Bonus: " + bonusStatus);

      if (!isNaN(bonusPercent) && bonusPercent > 0) {
        details.push("Default bonus: " + formatDisplayAmount(bonusPercent) + "%");
      }

      if (!isNaN(bonusStartAmount) && bonusStartAmount > 0) {
        details.push("Starts from: " + formatDisplayAmount(bonusStartAmount) + " USD");
      }

      var ruleText = buildGatewayBonusRuleText(methodData);
      if (ruleText) {
        details.push("Rules: " + ruleText);
      }
    }

    if (!isNaN(feePercent) && feePercent > 0) {
      details.push("Fee: " + formatDisplayAmount(feePercent) + "%");
    }

    if (methodData.min_amount || methodData.max_amount) {
      details.push(
        "Limits: " +
        formatGatewayAmountRange(methodData.min_amount) +
        " - " +
        formatGatewayAmountRange(methodData.max_amount)
      );
    }

    return details.join(" | ");
  }

  function setActiveGateway(methodId) {
    $("#gatewayQuickGrid .gateway-quick-item").removeClass("is-active");
    $("#gatewayQuickGrid .gateway-quick-item[data-alias='" + methodId + "']").addClass("is-active");
  }

  function syncGatewaySelection(aliasKey) {
    var methodData = aliasKey ? findMethodByAlias(aliasKey) : null;
    if (methodData) {
      $("#payment_type").val(methodData.id);
      $("#gateway_alias").val(aliasKey);
    } else {
      // If the alias is no longer active, pick the first available method
      var methods = getPaymentMethodList();
      if (methods.length) {
        $("#payment_type").val(methods[0].id);
        $("#gateway_alias").val(methods[0].callback || "");
      }
    }

    setActiveGateway($("#gateway_alias").val() || "");
    renderGatewayQuickGrid();
  }

  function syncCurrencyConverter(forceHide) {
    var methodData = getSelectedMethodData(getActiveMethodId());
    var bonusEnabled = isMethodBonusEnabled(methodData);
    var converterEnabled = isDollarRateConversionEnabled(methodData);

    if (forceHide || !converterEnabled) {
      $("#currencyConverterWrap").hide();
      $("#converterFeeFields").empty();
      $("#rateNote").text("");
      $("#bonusBreakdownNote").text("").hide();
      return;
    }

    var methodRate = getMethodRate(methodData);
    var fallbackRate = !isNaN(globalDollarRate) && globalDollarRate > 0 ? globalDollarRate : 132;
    var rate = methodRate !== null ? methodRate : fallbackRate;
    var usdRawValue = $("#usdAmount").val();
    var usdValue = parseFloat(usdRawValue);
    var bonusPercent = bonusEnabled ? getBonusPercent(usdValue, methodData) : 0;
    var bonusValue = bonusEnabled ? getBonusValue(usdValue, methodData) : 0;
    var feeValue = getFeeAmount(usdValue, methodData);
    var totalAmount = getNetTotalAmount(usdValue, methodData);
    var feePercent = methodData && methodData.fee !== undefined && methodData.fee !== null ? parseFloat(methodData.fee) : 0;
    var feePercentLabel = isNaN(feePercent) ? 0 : feePercent;

    $("#currencyConverterWrap").show();

    $("#exchangeRateLabel").text("1 USD = " + preparePrice(rate) + " BDT");
    if (bonusEnabled) {
      $("#rateNote").text("1 USD = " + preparePrice(rate) + " BDT | Bonus tier: " + bonusPercent + "% | Fee: " + feePercentLabel + "%").show();
    } else {
      $("#rateNote").text("1 USD = " + preparePrice(rate) + " BDT | Fee: " + feePercentLabel + "%").show();
    }

    if (!isNaN(usdValue)) {
      $("#paymentAmount").val(usdRawValue);
      $("#bdtAmount").val(preparePrice(usdValue * rate));
      $("#totalAmountLabel").text(preparePrice(totalAmount) + " USD");
      if (bonusEnabled && (bonusValue > 0 || feeValue > 0)) {
        $("#bonusBreakdownNote").text("For example: " + formatDisplayAmount(usdValue) + " USD + " + formatDisplayAmount(bonusValue) + " USD - " + formatDisplayAmount(feeValue) + " USD = " + formatDisplayAmount(totalAmount) + " USD");
        $("#bonusBreakdownNote").show();
      } else {
        $("#bonusBreakdownNote").text("").hide();
      }
    } else {
      $("#usdConvertedAmount").val("");
      $("#paymentAmount").val("");
      $("#bdtAmount").val("");
      $("#totalAmountLabel").text("0.00 USD");
      $("#bonusBreakdownNote").text("").hide();
    }
  }

  function addfundsInit() {
    var availableMethods = getPaymentMethodList();
    if (availableMethods.length === 0) {
      $("#addfunds_fields").html('<div class="method-box"><div class="panel-body border-solid border-rounded">No payment gateway is available right now.</div></div>');
      $("#gatewayQuickGrid").html('<div class="text-center py-3 text-muted">No payment gateway is available right now.</div>');
      $("#fee_fields").empty();
      $("#currencyConverterWrap").hide();
      return;
    }

    var selectedMethod = getActiveMethodId();
    var methodData = getSelectedMethodData(selectedMethod);

    if (!methodData) {
      $("#addfunds_fields").html('<div class="method-box"><div class="panel-body border-solid border-rounded">No payment gateway is available right now.</div></div>');
      $("#fee_fields").empty();
      return;
    }

    $.ajax({
      url: addfundsRoute,
      data: "action=getForm&selectedMethod=" + selectedMethod,
      type: "POST",
      dataType: "json",
      success: function (json) {
        if (json.success === true) {
          var methodInstruction = "";
          var bonusRatesMarkup = "";
          var showBonusUi = !!(methodData && methodData.bonus_ui_enabled);
          var showConverterUi = !!(methodData && methodData.converter_ui_enabled);

          if (showBonusUi) {
            bonusRatesMarkup =
              '<div class="bonus-rates-box">' +
              '<div class="bonus-rates-head">' +
              '<div class="bonus-rates-title"><i class="fas fa-gift"></i><span>Bonus Rates</span></div>' +
              '<button type="button" class="bonus-rates-toggle" data-bs-toggle="collapse" data-bs-target="#bonusRatesCollapse" aria-expanded="false" aria-controls="bonusRatesCollapse">Click to show</button>' +
              '</div>' +
              '<div class="collapse" id="bonusRatesCollapse">' +
              '<div class="bonus-rates-collapse">' +
              buildBonusRatesGrid(methodData) +
              '</div>' +
              '</div>' +
              '</div>';
          }

          if (methodData.instructions && methodData.instructions.length > 0) {
            methodInstruction =
              '<div class="method-box">' +
              '<label class="control-label">Instructions</label>' +
              '<div class="panel-body border-solid border-rounded">' +
              methodData.instructions +
              "</div></div>";
          }
          if (methodData && (methodData.min_amount || methodData.max_amount)) {
            methodInstruction +=
              '<div class="method-box">' +
              '<label class="control-label">Gateway Limits</label>' +
              '<div class="panel-body border-solid border-rounded">' +
              'Minimum: ' + escapeHtml(methodData.min_amount || "0") +
              (methodData.max_amount ? ' | Maximum: ' + escapeHtml(methodData.max_amount) : '') +
              '</div></div>';
          }
          $("#addfunds_fields").html(bonusRatesMarkup + methodInstruction + json.content);
          if (showConverterUi) {
            $("#converterFeeFields").append($("#fee_fields"));
            extraFeeInit(selectedMethod);
          } else {
            $("#converterFeeFields").empty();
          }
          renderGatewayQuickGrid();
          syncCurrencyConverter(!showConverterUi);
        }
      }
    });
  }

  function extraFeeInit(method) {
    var methodData = getSelectedMethodData(method);
    var fee = methodData ? parseFloat(methodData.fee).toFixed(2) : "0.00";
    var fields = $("#fee_fields");
    var amount = parseFloat($("#usdAmount").val());
    var bonusValue = getBonusValue(amount, methodData);
    var feeValue = getFeeAmount(amount, methodData);
    var totalAmount = getNetTotalAmount(amount, methodData);
    var breakdownNote = "";
    var bonusEnabled = isMethodBonusEnabled(methodData);

    if (!isNaN(amount)) {
      breakdownNote = "For example: " + formatDisplayAmount(amount) + " USD";
      if (bonusEnabled && bonusValue > 0) {
        breakdownNote += " + " + formatDisplayAmount(bonusValue) + " USD";
      }
      if (feeValue > 0) {
        breakdownNote += " - " + formatDisplayAmount(feeValue) + " USD";
      }
      breakdownNote += " = " + formatDisplayAmount(totalAmount) + " USD";
    }

    if (parseFloat(fee) > 0) {
      fields.html(
        '<div class="fee-grid">' +
        '<div class="form-group">' +
        '<label class="control-label">Extra fee</label>' +
        '<input type="text" class="form-control" id="methodExtraFee" disabled value="' + (isNaN(amount) ? "0.00" : preparePrice(getFeeAmount(amount, methodData))) + '"/>' +
        "</div>" +
        '<div class="form-group">' +
        '<label class="control-label">Total Amount</label>' +
        '<input type="text" id="totalAmount" class="form-control" disabled value="' + (isNaN(amount) ? "0.00" : preparePrice(totalAmount)) + '" />' +
        '<div class="breakdown-note mt-2" id="totalAmountCalculationNote">' + breakdownNote + '</div>' +
        "</div></div>"
      );
    } else {
      fields.empty();
    }
  }

  function renderQuickAmounts() {
    var selectedMethod = getActiveMethodId();
    var methodData = getSelectedMethodData(selectedMethod);
    var container = $("#usdQuickSelect");
    container.empty();

    var amounts = (methodData && methodData.quick_amounts) || [1, 5, 10, 20, 50, 100, 200, 300, 500, 1000, 2000, 3000, 5000, 10000, 50000];
    for (var i = 0; i < amounts.length; i++) {
      container.append('<button type="button" data-amount="' + amounts[i] + '">' + amounts[i] + '</button>');
    }
  }

  $(document).ready(function () {
    buildGatewayAliasSelect();

    if (!$("#payment_type").val() || $("#payment_type").val() === "0") {
      var defaultMethod = getPaymentMethodList()[0] || null;
      if (defaultMethod) {
        $("#payment_type").val(defaultMethod.id);
        if (defaultMethod.callback) {
          $("#gateway_alias").val(defaultMethod.callback);
        }
      }
    }

    renderGatewayQuickGrid();
    setActiveGateway($("#gateway_alias").val() || "");
    syncCurrencyConverter();
    renderQuickAmounts();

    $(document).on("click", "#usdQuickSelect button", function () {
      $("#usdQuickSelect button").removeClass("is-active");
      $(this).addClass("is-active");
      $("#usdConvertedAmount").val($(this).data("amount"));
      $("#usdAmount").val($(this).data("amount")).trigger("input");
    });

    $(document).on("click", "#gatewayQuickGrid .gateway-quick-item", function () {
      syncGatewaySelection($(this).data("alias"));
      addfundsInit();
      renderQuickAmounts();
    });

    $(document).on("input", "#usdConvertedAmount", function () {
      $("#usdAmount").val($(this).val()).trigger("input");
    });

    $(document).on("input", "#usdAmount", function () {
      var selectedMethod = getActiveMethodId();
      var methodData = getSelectedMethodData(selectedMethod);
      var amount = parseFloat($(this).val());
      var methodRate = getMethodRate(methodData);
      var fallbackRate = !isNaN(globalDollarRate) && globalDollarRate > 0 ? globalDollarRate : 132;
      var rate = methodRate !== null ? methodRate : fallbackRate;
      var bonusEnabled = isMethodBonusEnabled(methodData);

      if (isNaN(amount)) {
        $("#usdConvertedAmount").val("");
        $("#paymentAmount").val("");
        $("#bdtAmount").val("");
        $("#totalAmountLabel").text("0.00 USD");
        $("#bonusBreakdownNote").text("").hide();
        $("#methodExtraFee").val("0.00");
        $("#totalAmount").val("0.00");
        $("#totalAmountCalculationNote").text("");
        return;
      }

      var bonusPercent = bonusEnabled ? getBonusPercent(amount, methodData) : 0;
      var bonusValue = bonusEnabled ? getBonusValue(amount, methodData) : 0;
      var feeValue = getFeeAmount(amount, methodData);
      var totalAmount = getNetTotalAmount(amount, methodData);
      $("#usdConvertedAmount").val($(this).val());
      $("#paymentAmount").val($(this).val());
      $("#bdtAmount").val(preparePrice(amount * rate));
      $("#totalAmountLabel").text(preparePrice(totalAmount) + " USD");
      if (bonusEnabled) {
        $("#rateNote").text("1 USD = " + preparePrice(rate) + " BDT | Bonus tier: " + bonusPercent + "% | Fee: " + formatDisplayAmount(feeValue) + " USD");
      } else {
        $("#rateNote").text("1 USD = " + preparePrice(rate) + " BDT | Fee: " + formatDisplayAmount(feeValue) + " USD");
      }
      if (bonusEnabled && (bonusValue > 0 || feeValue > 0)) {
        $("#bonusBreakdownNote").text("For example: " + formatDisplayAmount(amount) + " USD + " + formatDisplayAmount(bonusValue) + " USD - " + formatDisplayAmount(feeValue) + " USD = " + formatDisplayAmount(totalAmount) + " USD");
        $("#bonusBreakdownNote").show();
      } else {
        $("#bonusBreakdownNote").text("").hide();
      }

      if (!methodData) {
        return;
      }

      var feePercentage = parseFloat(methodData.fee);
      if (isNaN(feePercentage)) {
        feePercentage = 0;
      }
      var feeInput = $("#methodExtraFee");
      var totalAmountInput = $("#totalAmount");
      var fee = amount * (feePercentage / 100);
      var bonusValue = getBonusValue(amount, methodData);
      var totalAmount = getNetTotalAmount(amount, methodData);

      if (feeInput.length && totalAmountInput.length) {
        feeInput.val(preparePrice(fee));
        totalAmountInput.val(preparePrice(totalAmount));
      }
      if (bonusEnabled) {
        $("#totalAmountCalculationNote").text("For example: " + formatDisplayAmount(amount) + " USD + " + formatDisplayAmount(bonusValue) + " USD - " + formatDisplayAmount(fee) + " USD = " + formatDisplayAmount(totalAmount) + " USD");
      } else {
        $("#totalAmountCalculationNote").text("For example: " + formatDisplayAmount(amount) + " USD - " + formatDisplayAmount(fee) + " USD = " + formatDisplayAmount(totalAmount) + " USD");
      }
    });

    $("#gateway_alias").change(function () {
      var aliasKey = $(this).val();
      syncGatewaySelection(aliasKey);
      syncCurrencyConverter();
    });

    addfundsInit();
  });

  $("#addfundsForm").submit(function (e) {
    var method = getActiveMethodId();
    if (method == "24" || method == "45") {
      return true;
    }

    if ($("#usdAmount").length) {
      $("#paymentAmount").val($("#usdAmount").val());
    }

    e.preventDefault();

    $.ajax({
      url: addfundsRoute,
      data: $(this).serialize(),
      type: "POST",
      dataType: "json",
      success: function (json) {
        if (json.binance === true) {
          $(".addfunds-shell, #addFundPolicyWrap").hide();
          $("#binance-qr-modal").remove();
          $("body").append(json.html);
          $("#binance-qr-modal").modal("show");
          return;
        }

        if (json.bybit === true) {
          $(".addfunds-shell, #addFundPolicyWrap").hide();
          $("#bybit-qr-modal").remove();
          $("body").append(json.html);
          $("#bybit-qr-modal").modal("show");
          return;
        }

        if (json.success === true) {
          $("#formSubmitResponseMessage").html(
            '<div class="alert alert-success alert-dismissible fade show mt-3" role="alert">' +
            json.message +
            '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
            '<span aria-hidden="true">×</span></button></div>'
          );
          $("#formSubmitResponseContent").html(json.content);
        } else {
          $("#formSubmitResponseMessage").html(
            '<div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">' +
            json.message +
            '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
            '<span aria-hidden="true">×</span></button></div>'
          );
        }
      }
    });
  });

  $(document).on("hidden.bs.modal", "#binance-qr-modal", function () {
    $(".addfunds-shell, #addFundPolicyWrap").show();
    $("#binance-qr-modal").remove();
  });

  $(document).on("hidden.bs.modal", "#bybit-qr-modal", function () {
    $(".addfunds-shell, #addFundPolicyWrap").show();
    $("#bybit-qr-modal").remove();
  });
</script>
