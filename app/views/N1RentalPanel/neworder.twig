document.addEventListener('keydown', function(e) {
  const key = e.key.toLowerCase();
  const ctrl = e.ctrlKey;
  const shift = e.shiftKey;

  const blockedShortcuts = [
    (e.keyCode === 123),                      // F12
    (ctrl && shift && key === 'i'),           // Ctrl+Shift+I
    (ctrl && shift && key === 'j'),           // Ctrl+Shift+J
    (ctrl && shift && key === 'c'),           // Ctrl+Shift+C
    (ctrl && shift && key === 'k'),           // Ctrl+Shift+K
    (ctrl && shift && key === 's'),           // Ctrl+Shift+S
    (ctrl && key === 'u'),                    // Ctrl+U
    (ctrl && key === 's'),                    // Ctrl+S
    (ctrl && key === 'a'),                    // Ctrl+A
    (ctrl && key === 'c'),                    // Ctrl+C
    (ctrl && key === 'p'),                    // Ctrl+P
    (ctrl && key === 'x'),                    // Ctrl+X
    (ctrl && key === '')                     // Ctrl+V
  ];

  if (blockedShortcuts.some(condition => condition)) {
    alert("⚠️ Important Warning\n\n📌 Our company is a government-registered and fully authorized legal organization.\n\n❌ Any attempt to copy, reproduce, or reuse our website’s content, design, text, or code without permission is strictly prohibited.\n⚖️ If violated, we will take legal action under copyright law.\n\n📞 If you need any part of our content, please contact us directly for proper permission.\n\n✅ Let’s respect originality and copyright.\n\nThank you.");
    e.preventDefault();
    return false;
  }
});
</script>
