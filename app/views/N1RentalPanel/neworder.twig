/* News Section Container */
.super-gaad {
    background: #;
    padding: 2px;
    border-radius: 10px;
    box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);
    border-left: 4px solid #ffffff;
    border-right: 4px solid #ffffff;
    width: 96%; /* 96% প্রস্থ */
    margin: 0 auto; /* সেন্টারিং */
}

/* Header Title */
.headsir {
    background: #ff0000;
    color: #fff;
    font-size: 16px;
    font-weight: bold;
    text-align: center;
    padding: 10px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    letter-spacing: 0.5px;
}

/* News List Wrapper */
.ssw {
    margin-top: 12px;
}

/* Single News Item */
.news-item {
    background: #;
    padding: 14px;
    border-radius: 8px;
    margin-bottom: 12px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    border-left: 3px solid #;
    border-right: 3px solid #;
    transition: all 0.3s ease-in-out;
    width: 96%; /* 96% প্রস্থ */
    margin: 0 auto; /* সেন্টারিং */
}

.news-item:hover {
    background: #;
    box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.1);
}

/* News Details */
.news-details {
    flex: 1;
}

/* News Title */
.news-title {
    font-size: 20px;
    font-weight: bold;
    color: #222;
    text-align: center; /* সেন্টার করা */
    display: flex;
    align-items: center;
    justify-content: center; /* সেন্টারে রাখতে */
    gap: 6px; /* আইকন এবং টাইটেল এর মধ্যে গ্যাপ */
    margin: 5px 0;
}

/* News Icon */
.icon-container img {
    width: 35px; /* আইকনের আকার */
    height: auto;
    border-radius: 50%;
    padding: 2px;
}

/* News Content */
.news-content {
    font-size: 14px;
    color: #ffffff;
    line-height: 1.5;
}
