<style>
.main-section {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  margin: 20px auto;
  padding: 10px;
  position: relative;
}

.image-section {
  position: relative;
  width: 40%;
  margin-right: 20px;
  overflow: hidden;
}

.rotating-img {
  width: 100%;
  height: auto;
  border-radius: 50%;
  animation: rotate 10s linear infinite;
}

.center-img {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 50%;
  height: auto;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  z-index: 10;
}

.text-section {
  width: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 20px;
}

.text-section h1 {
  font-size: 40px;
  margin-bottom: 15px;
}

.text-section p {
  font-size: 16px;
  line-height: 1.5;
}

.text-section .btn {
  font-size: 18px;
  padding: 10px 20px;
  text-decoration: none;
  background-color: #007bff;
  color: #fff;
  border-radius: 5px;
  text-align: center;
}

@keyframes rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Responsive Design */
@media (max-width: 768px) {
  .main-section {
    flex-direction: column;
    text-align: center;
  }

  .image-section, .text-section {
    width: 100% !important;
    margin: 0 auto 20px auto;
  }

  .rotating-img {
    width: 100%;
  }

  .center-img {
    width: 50%;
  }

  .text-section h1 {
    font-size: 22px;
  }

  .text-section p {
    font-size: 15px;
    padding: 0 10px;
  }

  .btn {
    display: inline-block;
    font-size: 16px;
  }
}
</style>
