<style>
/* Define the typing effect */
@keyframes typing {
    0% {
        width: 0;
        opacity: 0;
    }
    100% {
        width: 100%;
        opacity: 1;
    }
}

/* Apply typing effect to the title */
.typing {
    font-size: 32px;
    font-weight: bold;
    white-space: nowrap;
    overflow: hidden;
}

/* Style for the lines */
.line1, .line2 {
    display: block; /* Make each line a block-level element */
    white-space: nowrap; /* Prevent text from wrapping */
    overflow: hidden;
    width: 0;
    animation: typing 3s steps(20) forwards; /* Adjust steps based on text length */
}

.line1 {
    animation-delay: 0s; /* Starts immediately */
}

.line2 {
    animation-delay: 3s; /* Starts after the first line finishes */
}

/* Simulate the blinking cursor for each line */
@keyframes blink {
    0% {
        border-color: transparent;
    }
    50% {
        border-color: black;
    }
    100% {
        border-color: transparent;
    }
}

/* Add a blinking cursor effect */
.typing {
    border-right: 2px solid black; /* Simulates the cursor */
    animation: blink 0.75s step-end infinite;
}
</style>
