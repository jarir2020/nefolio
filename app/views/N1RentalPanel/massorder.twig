{% include 'header.twig' %}

  <div class="content">
        <!-- page and other top info -->
        <div id="page_info">

        </div>
        <!-- // page and other top info -->
   <!-- Mass Order Part -->
<div class="def_wraper">
   <div class="container-fluid">
      <div class="row">
         <div class="col-md-6">
            <div class="card card_v2">
               <div class="card-header v2_header">
                   <div class="new_order_tabs">
                      <ul class="nav nav-pills" id="pills-tab" role="tablist">
                         <li class="nav-item" role="presentation">
                            <button class="nav-link" onclick="window.location.href='/'" id="pills-order-tab" data-bs-toggle="pill" data-bs-target="#pills-order" type="button" role="tab" aria-controls="pills-order" aria-selected="true"> 
                               <span class="icon"><i class="fas fa-shopping-cart"></i></span>
                               <span class="text_name"> New Order</span>
                            </button>
                         </li>
                         <li class="nav-item " role="presentation">
                            <button class="nav-link active" id="pills-auto-tab" data-bs-toggle="pill" data-bs-target="#pills-auto" type="button" role="tab" aria-controls="pills-auto" aria-selected="false"> 
                               <span class="icon"><i class="fas fa-list-ol"></i></span>
                               <span class="text_name"> Mass Order</span>
                            </button>
                         </li>
                      </ul>
                     </div>
                </div>
               <div class="card-body">
                  <div class="tab-content tab_wrap" id="pills-tabContent">
                     <div class="tab-pane fade show active" id="pills-order" role="tabpanel" aria-labelledby="pills-order-tab">
                      
                        {% if error %}
        <div class="alert alert-dismissible alert-danger {% if site['rtl'] %} rtl-alert {% endif %}">
          <button type="button" class="close" data-dismiss="alert">×</button>
          {{ errorText }}
        </div>
      {% elseif success %}
        <div class="alert alert-dismissible alert-success {% if site['rtl'] %} rtl-alert {% endif %}">
          <button type="button" class="close" data-dismiss="alert">×</button>
          {{ successText }}
        </div>
      {% endif %}


                            <form  method="post" action="/massorder">
                                                                                           <div class="form-group">
                               <label for="links" class="control-label">One order per line in format</label>
                               <textarea class="form-control massorder_textarea" id="mass" name="mass" value="{{ data['mass'] }}" rows="15" placeholder="Service Id | Quantity | link"></textarea>
                           </div>
                         
                         
                           <button type="submit" class="btn btn-primary d-block w-100">Submit</button>
                       </form>
                     </div>
                  </div>
               </div>
            </div>
         </div>
         
      </div>
   </div>
 </div>
 <!-- // Mass Order Part -->
                </div>
            </div>
        </main>
          
	
	




{% include 'footer.twig' %}